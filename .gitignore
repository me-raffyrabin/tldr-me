# --- Dependencies ---
node_modules/
jspm_packages/
.pnp
.pnp.js
.yarn/*
!.yarn/releases
!.yarn/plugins

# --- Build output ---
dist/
build/
out/
.cache/
.parcel-cache/
.vite/
.next/
.nuxt/
.svelte-kit/

# --- Logs ---
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Environment / secrets ---
# Nothing here needs an API key today, but don't let one leak in later.
.env
.env.*
!.env.example
*.pem
*.key

# --- OS cruft ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Editors / IDEs ---
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
*.sublime-workspace

# --- Claude Code ---
# .claude/launch.json is shared config and SHOULD be committed.
.claude/settings.local.json

# --- Local testing artifacts ---
# Headless Chrome profiles used by scripts/make-icons.mjs and manual testing.
chrome-profile/
.chrome-icons-profile/
.playwright-cli/
.tmp/
scratch/
coverage/

# --- Model weights ---
# Models are downloaded at runtime and cached by the browser, never committed.
# This only matters if you ever choose to self-host them.
*.wasm
*.bin
*.onnx
*.safetensors
models/
